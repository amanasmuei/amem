{
  "name": "engram",
  "version": "0.1.0",
  "description": "The memory layer for AI coding tools. Local-first, developer-specific, works everywhere.",
  "type": "module",
  "bin": {
    "engram": "dist/index.js",
    "engram-cli": "dist/cli.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "npm run build",
    "start": "node dist/index.js"
  },
  "keywords": ["mcp", "memory", "ai", "developer-tools", "context", "sqlite", "embeddings"],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.2",
    "better-sqlite3": "^12.0.0",
    "zod": "^3.25.0"
  },
  "optionalDependencies": {
    "@huggingface/transformers": "^3.8.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}

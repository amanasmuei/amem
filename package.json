{
  "name": "@aman_asmuei/amem",
  "version": "0.19.0",
  "description": "The memory layer for AI coding tools. Local-first, developer-specific, works everywhere.",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "amem": "dist/index.js",
    "amem-cli": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/index.js dist/cli.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "npm run build",
    "start": "node dist/index.js"
  },
  "keywords": [
    "mcp",
    "memory",
    "ai",
    "developer-tools",
    "context",
    "sqlite",
    "embeddings"
  ],
  "license": "MIT",
  "author": "Aman Asmuei",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amanasmuei/amem.git"
  },
  "homepage": "https://github.com/amanasmuei/amem#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@aman_asmuei/amem-core": "file:../amem-core",
    "@modelcontextprotocol/sdk": "^1.25.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
